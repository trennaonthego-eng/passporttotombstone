# Copy this file to .env.local and fill in the values from your Supabase project
# (Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public URL of the deployed site (used in structured data)
NEXT_PUBLIC_SITE_URL=https://passporttotombstone.com

# Optional: Resend API key for newsletter sending (not required for MVP)
RESEND_API_KEY=

# Optional: powers the AI concierge with real Claude replies. Without this,
# the concierge still works using a local keyword matcher over the business
# and event data — just without conversational LLM answers.
ANTHROPIC_API_KEY=

# Admin panel (/admin). ADMIN_PASSWORD is the login your VA uses.
# SUPABASE_SERVICE_ROLE_KEY comes from Supabase → Project Settings → API →
# service_role (keep it secret — server-side only, never exposed to browsers).
ADMIN_PASSWORD=
SUPABASE_SERVICE_ROLE_KEY=
