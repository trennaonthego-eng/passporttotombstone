# Copy this file to .env.local and fill in the values from your Supabase project
# (Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public URL of the deployed site (used in structured data)
NEXT_PUBLIC_SITE_URL=https://passporttotombstone.com

# Optional: Resend API key for newsletter sending (not required for MVP)
RESEND_API_KEY=

# Optional: powers the AI concierge with real Claude replies. Without this,
# the concierge still works using a local keyword matcher over the business
# and event data — just without conversational LLM answers.
ANTHROPIC_API_KEY=

# Admin panel (/admin). ADMIN_PASSWORD is the login your VA uses.
# SUPABASE_SERVICE_ROLE_KEY comes from Supabase → Project Settings → API →
# service_role (keep it secret — server-side only, never exposed to browsers).
ADMIN_PASSWORD=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (/upgrade — pay-to-upgrade partnership checkout).
# Get STRIPE_SECRET_KEY from Stripe Dashboard → Developers → API keys.
# Create 3 recurring Products (Featured $49/mo, Premium $99/mo, Newsletter
# Sponsor $25/mo) → Product catalog, and paste each Price ID below.
# For the launch promo (50% off for the first 3 months): Product catalog →
# Coupons → New: 50% off, Duration = "Multiple months", 3 months. Then create
# a Promotion Code on that coupon (e.g. TOMBSTONE50) — checkout already has
# the promo-code box enabled, so partners just type it in.
# STRIPE_WEBHOOK_SECRET comes from Developers → Webhooks → your endpoint's
# signing secret, after you add https://yoursite.com/api/stripe/webhook
# listening for checkout.session.completed and customer.subscription.deleted.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FEATURED=
STRIPE_PRICE_PREMIER=
STRIPE_PRICE_SPONSOR=

# Optional: signs the passport stamp QR codes (/passport program). Any long
# random string. If unset, the SUPABASE_SERVICE_ROLE_KEY is used instead, so
# the program works without this — but setting a dedicated secret means you
# can rotate/reprint all stamp QR codes without touching Supabase keys.
STAMP_SECRET=
